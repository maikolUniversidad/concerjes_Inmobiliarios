{
  "name": "conserjes-inmobiliarios",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:inventario": "turbo run dev --filter=inventario",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "pg": "^8.22.0"
  },
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=20.0.0"
  }
}
