generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Producto {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sku             String      @unique @db.VarChar(30)
  codigoBarras    String?     @unique @db.VarChar(50) @map("codigo_barras")
  nombre          String      @db.VarChar(200)
  descripcion     String?
  categoria       Categoria
  subcategoria    String?     @db.VarChar(100)
  unidadMedida    UnidadMedida @map("unidad_medida")
  precioCosto     Decimal?    @db.Decimal(12, 2) @map("precio_costo")
  precioReferencia Decimal?   @db.Decimal(12, 2) @map("precio_referencia")
  stockMinimo     Decimal     @default(0) @db.Decimal(10, 2) @map("stock_minimo")
  stockMaximo     Decimal?    @db.Decimal(10, 2) @map("stock_maximo")
  proveedorId     String?     @db.Uuid @map("proveedor_id")
  imagenUrl       String?     @map("imagen_url")
  imagenIaRef     String?     @map("imagen_ia_ref")
  activo          Boolean     @default(true)
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  proveedor       Proveedor?  @relation(fields: [proveedorId], references: [id])
  stock           Stock[]
  movimientos     Movimiento[]

  @@map("productos")
}

model Bodega {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre          String      @db.VarChar(200)
  tipo            TipoBodega
  direccion       String?
  responsableId   String?     @db.Uuid @map("responsable_id")
  contratoId      String?     @db.Uuid @map("contrato_id")
  activo          Boolean     @default(true)

  contrato        Contrato?   @relation(fields: [contratoId], references: [id])
  stock           Stock[]
  movimientosOrigen   Movimiento[] @relation("BodegaOrigen")
  movimientosDestino  Movimiento[] @relation("BodegaDestino")

  @@map("bodegas")
}

model Stock {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productoId        String    @db.Uuid @map("producto_id")
  bodegaId          String    @db.Uuid @map("bodega_id")
  cantidad          Decimal   @default(0) @db.Decimal(10, 2)
  lote              String?   @db.VarChar(100)
  fechaVencimiento  DateTime? @map("fecha_vencimiento") @db.Date
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  producto          Producto  @relation(fields: [productoId], references: [id])
  bodega            Bodega    @relation(fields: [bodegaId], references: [id])

  @@unique([productoId, bodegaId, lote])
  @@map("stock")
}

model Movimiento {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tipo              TipoMovimiento
  productoId        String        @db.Uuid @map("producto_id")
  bodegaOrigenId    String?       @db.Uuid @map("bodega_origen_id")
  bodegaDestinoId   String?       @db.Uuid @map("bodega_destino_id")
  cantidad          Decimal       @db.Decimal(10, 2)
  precioUnitario    Decimal?      @db.Decimal(12, 2) @map("precio_unitario")
  numeroDocumento   String?       @db.VarChar(100) @map("numero_documento")
  contratoId        String?       @db.Uuid @map("contrato_id")
  observacion       String?
  usuarioId         String        @db.Uuid @map("usuario_id")
  iaOrigen          Boolean       @default(false) @map("ia_origen")
  iaConfianza       Decimal?      @db.Decimal(3, 2) @map("ia_confianza")
  comprobanteUrl    String?       @map("comprobante_url")
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz

  producto          Producto      @relation(fields: [productoId], references: [id])
  bodegaOrigen      Bodega?       @relation("BodegaOrigen", fields: [bodegaOrigenId], references: [id])
  bodegaDestino     Bodega?       @relation("BodegaDestino", fields: [bodegaDestinoId], references: [id])
  contrato          Contrato?     @relation(fields: [contratoId], references: [id])

  @@map("movimientos")
}

model Contrato {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  codigo              String    @unique @db.VarChar(50)
  clienteNombre       String    @db.VarChar(200) @map("cliente_nombre")
  tipoServicio        String[]  @map("tipo_servicio")
  fechaInicio         DateTime? @map("fecha_inicio") @db.Date
  fechaFin            DateTime? @map("fecha_fin") @db.Date
  presupuestoDotacion Decimal?  @db.Decimal(14, 2) @map("presupuesto_dotacion")
  responsableId       String?   @db.Uuid @map("responsable_id")
  activo              Boolean   @default(true)

  bodegas             Bodega[]
  movimientos         Movimiento[]

  @@map("contratos")
}

model Proveedor {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre          String    @db.VarChar(200)
  nit             String?   @unique @db.VarChar(20)
  contactoNombre  String?   @db.VarChar(200) @map("contacto_nombre")
  telefono        String?   @db.VarChar(20)
  email           String?   @db.VarChar(200)
  activo          Boolean   @default(true)

  productos       Producto[]

  @@map("proveedores")
}

enum Categoria {
  ASEO
  CAFETERIA
  EPP
  MAQUINARIA
  JARDINERIA
  CONSUMIBLES
  REPUESTOS
  OTROS
}

enum UnidadMedida {
  UNIDAD
  LITRO
  KILOGRAMO
  METRO
  CAJA
  BOLSA
  GALON
  ROLLO
}

enum TipoBodega {
  BODEGA_CENTRAL
  SEDE_CLIENTE
  VEHICULO
}

enum TipoMovimiento {
  ENTRADA
  SALIDA
  TRASLADO
  AJUSTE
  DEVOLUCION
}
